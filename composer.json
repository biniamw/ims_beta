{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^7.4|8.0",
        "barryvdh/laravel-dompdf": "^0.9.0",
        "beyondcode/laravel-websockets": "^1.12",
        "cloudinary-labs/cloudinary-laravel": "^1.0",
        "consoletvs/charts": "^6.5",
        "consoletvs/invoices": "^1.8",
        "fideloper/proxy": "^4.4",
        "fruitcake/laravel-cors": "^2.0",
        "guzzlehttp/guzzle": "^7.0.1",
        "illuminate/support": "*",
        "intervention/image": "^2.7",
        "jenssegers/date": "^4.0",
        "jimmyjs/laravel-report-generator": "^2.0",
        "koolreport/bootstrap4": "^1.5",
        "koolreport/core": "^5.1",
        "koolreport/laravel": "^2.0",
        "laravel/framework": "^8.0",
        "laravel/sail": "^1.0",
        "laravel/tinker": "^2.5",
        "laravel/ui": "^3.2",
        "laravelcollective/html": "^6.2",
        "laraveldaily/laravel-invoices": "^2.0",
        "maatwebsite/excel": "^3.1",
        "milon/barcode": "^8.0",
        "mpdf/mpdf": "^8.0",
        "nesbot/carbon": "^2.64.0",
        "php-mqtt/laravel-client": "^1.3",
        "picqer/php-barcode-generator": "^2.2",
        "pusher/pusher-php-server": "~5.0",
        "salmanzafar/laravel-mqtt": "^2.0",
        "samuelterra22/laravel-report-generator": "^5.2",
        "spatie/laravel-permission": "^4.0",
        "symfony/process": "^5.4",
        "uxweb/sweet-alert": "^2.0",
        "violuke/php-barcodes": "^1.0",
        "yajra/laravel-datatables-buttons": "^4.13",
        "yajra/laravel-datatables-oracle": "^9.17"
    },
    "require-dev": {
        "facade/ignition": "^2.5",
        "fakerphp/faker": "^1.9.1",
        "laravel/sail": "^1.0.1",
        "mockery/mockery": "^1.4.2",
        "nunomaduro/collision": "^5.0",
        "phpunit/phpunit": "^9.3.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "rlt3\\Barcode\\": "",
            "SamuelTerra22\\ReportGenerator\\": "src/"
        },
        "files": [
            "app/Helpers/LoggerHelper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "SamuelTerra22\\ReportGenerator\\ServiceProvider"
            ],
            "aliases": {
                "PdfReport": "SamuelTerra22\\ReportGenerator\\Facades\\PdfReportFacade",
                "ExcelReport": "SamuelTerra22\\ReportGenerator\\Facades\\ExcelReportFacade",
                "CSVReport": "SamuelTerra22\\ReportGenerator\\Facades\\CSVReportFacade::class"
            },
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "platform": {
            "php": "7.4.3"
        },
        "platform-check": false
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}